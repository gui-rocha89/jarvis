# ============================================
# JARVIS 2.0 - Variáveis de Ambiente
# Copie para .env e preencha com seus valores
# ============================================

# --- API Keys ---
ANTHROPIC_API_KEY=sua-chave-anthropic
ASANA_PAT=seu-token-asana
OPENAI_API_KEY=sua-chave-openai
ELEVENLABS_API_KEY=sua-chave-elevenlabs
ELEVENLABS_VOICE_ID=id-da-voz-elevenlabs

# --- Jarvis API ---
JARVIS_API_KEY=sua-chave-secreta-para-api
API_PORT=3100

# --- Dashboard Security (JWT) ---
JWT_SECRET=gere-com-node-e-console-log-require-crypto-randomBytes-64-toString-hex

# --- Modelo de IA ---
AI_MODEL=claude-sonnet-4-6
AI_MODEL_STRONG=claude-opus-4-0-20250514
MEMORY_MODEL=claude-3-haiku-20240307

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jarvis
DB_USER=jarvis
DB_PASSWORD=sua-senha-postgres

# --- Redis ---
REDIS_PASSWORD=sua-senha-redis

# --- WhatsApp (JIDs) ---
GUI_JID=seu-numero@s.whatsapp.net
GROUP_TAREFAS=id-do-grupo@g.us
GROUP_GALAXIAS=id-do-grupo@g.us

# --- Asana ---
ASANA_WORKSPACE=seu-workspace-id
TEAM_ASANA={"nome1":"gid1","nome2":"gid2"}
ASANA_PROJECTS={"CAPTACAO":"gid","AUDIOVISUAL":"gid","DESIGN":"gid","CABINE":"gid"}
ASANA_SECTIONS={"AV_CAPTACAO":"gid"}
PUBLIC_ASANA_PROJECTS=gid1,gid2,gid3,gid4
ASANA_CUSTOM_FIELDS={"CLIENTE_FIELD":"gid","DESCARTE_FIELD":"gid","URGENCIA_FIELD":"gid","TIER_FIELD":"gid","TIPO_DEMANDA_FIELD":"gid"}
ASANA_CLIENTE_MAP={"minner":"gid","pippi":"gid","digal":"gid","callegaro":"gid"}
ASANA_URGENCIA_MAP={"24h":"gid","48h":"gid","72h":"gid","negociavel":"gid"}
ASANA_TIER_MAP={"s":"gid","a":"gid","b":"gid","c":"gid","m":"gid"}
ASANA_TIPO_DEMANDA_MAP={"design":"gid","audiovisual":"gid","endomarketing":"gid","marketing":"gid","reuniao":"gid","planejamento":"gid","demanda_extra":"gid","captacao":"gid"}

# --- Google Calendar ---
GCAL_KEY_PATH=/opt/jarvis/google-calendar-key.json
GCAL_CALENDAR_ID=seu-email@dominio.com
